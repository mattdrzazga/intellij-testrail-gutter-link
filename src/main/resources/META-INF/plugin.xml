<idea-plugin>
    <id>com.mateo.plugins.testraillink</id>
    <name>TestRail Gutter Link</name>
    <vendor>Mateusz Drzazga</vendor>

    <description><![CDATA[
        Adds a gutter icon on every <code>@TestCase(testCaseId = "...")</code>
        annotation line in Java and Kotlin test sources. Clicking the icon opens
        the matching TestRail case
        (<code>https://example.testrail.io/index.php?/cases/view/&lt;id&gt;</code>)
        in the default browser.<br/>
        <br/>
        Matches any annotation whose simple name is <code>TestCase</code> and
        that is applied to a method, regardless of its package. Works with both
        the K1 and K2 Kotlin compiler modes.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <codeInsight.lineMarkerProvider
            language="JAVA"
            implementationClass="com.mateo.plugins.testraillink.TestCaseLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider
            language="kotlin"
            implementationClass="com.mateo.plugins.testraillink.TestCaseLineMarkerProvider"/>
        <projectConfigurable
            parentId="tools"
            id="com.mateo.plugins.testraillink.settings"
            displayName="TestRail Gutter Link"
            instance="com.mateo.plugins.testraillink.TestRailSettingsConfigurable"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="true" supportsK2="true"/>
    </extensions>
</idea-plugin>
